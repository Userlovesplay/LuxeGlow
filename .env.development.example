# ==========================================
# LuxeGlow - Development Environment
# ==========================================
# Copy this file to .env.development.local for local development
# NEVER commit .env.development.local to version control
# ==========================================

# ==========================================
# HMR Configuration (Hot Module Replacement)
# ==========================================
# Uncomment if you have WebSocket connection issues during development

# NEXT_EXPERIMENTAL_DISABLE_HMR=false
# NEXT_DEVELOPMENT_DEBUG=false

# ==========================================
# Disable Telemetry
# ==========================================
# Opt-out of Next.js telemetry
DISABLE_NEXT_INTERNAL_TELEMETRY=true

# ==========================================
# Development Debugging
# ==========================================
# Uncomment for detailed debugging
# DEBUG=*
# NODE_DEBUG_NATIVE=fs

# ==========================================
# API Configuration for Development
# ==========================================
# Use the same keys from .env.local
# Or use test/development keys if you have separate ones

# AI_PROVIDER=openrouter
# OPENROUTER_API_KEY=your_dev_openrouter_key
# GOOGLE_API_KEY=your_dev_google_key

# ==========================================
# Network Configuration
# ==========================================
# For accessing from other devices on the network
# Uncomment if needed, otherwise use: npm run dev:host

# NEXT_PUBLIC_HOSTNAME=0.0.0.0
# NEXT_PUBLIC_PORT=3000

# ==========================================
# Feature Flags (Optional)
# ==========================================
# Enable/disable features during development

# NEXT_PUBLIC_ENABLE_ANALYTICS=false
# NEXT_PUBLIC_ENABLE_NEWSLETTER=true
# NEXT_PUBLIC_DEBUG_MODE=false

# ==========================================
# Notes
# ==========================================
# 1. Use 'npm run dev:host' to allow connections from other IPs
# 2. Use 'npm run dev:ip' to bind to specific IP (configure in package.json)
# 3. Use 'npm run dev' for localhost only (default)
# ==========================================

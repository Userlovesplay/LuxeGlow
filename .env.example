# ==========================================
# LuxeGlow - Environment Configuration
# ==========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ==========================================

# ==========================================
# AI Provider Selection
# ==========================================
# Options: "google" or "openrouter"
# Default: "openrouter" (recommended for free tier)
AI_PROVIDER=openrouter

# ==========================================
# OpenRouter Configuration (Recommended)
# ==========================================
# Get your free API key from: https://openrouter.ai/
# Features:
#   - Free tier with generous limits
#   - Supports multiple models
#   - No credit card required for free tier
#
# Example format: sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ==========================================
# Google Gemini Configuration (Alternative)
# ==========================================
# Get your free API key from: https://aistudio.google.com/app/apikey
# Features:
#   - Free tier available
#   - Supports Gemini models
#   - Requires project setup
#
# Example format: AIzaSyAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_API_KEY=your_google_api_key_here

# ==========================================
# Google Custom Search (Optional)
# ==========================================
# Only needed if you want to implement search features
# Get from: https://programmablesearchengine.google.com/
GOOGLE_CSE_ID=your_google_cse_id_here

# ==========================================
# Development Settings (Optional)
# ==========================================
# Disable HMR if you have connection issues
# NEXT_EXPERIMENTAL_DISABLE_HMR=false

# ==========================================
# Analytics (Optional)
# ==========================================
# For Vercel Analytics - automatically detected if deployed on Vercel
# No configuration needed - just deploy!

# ==========================================
# Notes for Developers
# ==========================================
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in your API keys in .env.local
# 3. NEVER commit .env.local
# 4. .env.local is in .gitignore for safety
# 5. For production, use your hosting platform's environment variables
#
# Quick Start:
#   - Recommended: Use OpenRouter (free tier works great)
#   - Alternative: Use Google Gemini (also free)
# ==========================================
